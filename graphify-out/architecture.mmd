flowchart TD
    Client[Mobile or Web Client]
    Admin[Admin Browser]

    subgraph Routes
        ApiRoutes[routes/api.php]
        WebRoutes[routes/web.php]
    end

    subgraph API_V1[API v1 Controllers]
        AuthC[AuthController]
        GroupC[GroupController]
        GroupMemberC[GroupMemberController]
        ExpenseC[ExpenseController]
        SettlementC[SettlementController]
        BalanceC[BalanceController]
        StatementC[StatementController]
    end

    subgraph LegacyWeb[Legacy Web Controllers]
        LegacyExpenseC[ExpenseController]
        AdminDashC[Admin DashboardController]
        AdminSettingsC[Admin SettingsController]
        MediaC[PublicMediaController]
    end

    subgraph Domain
        GroupM[Group]
        UserM[User]
        ExpenseM[Expense]
        SettlementM[Settlement]
        StatementRecordM[StatementRecord]
        InvitationM[GroupInvitation]
    end

    subgraph Services
        BalanceS[BalanceService]
        PayloadS[ApiPayload]
        Mailers[ExpenseCreatedMail and SettlementCreatedMail]
    end

